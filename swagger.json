{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora API",
    "description": "REST API для колекції букетів Flora",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/api", "description": "API base path" }
  ],
  "paths": {
    "/bouquets": {
      "get": {
        "summary": "Список букетів",
        "tags": ["Bouquets"],
        "parameters": [
          { "name": "_page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "_limit", "in": "query", "schema": { "type": "integer", "default": 8 } }
        ],
        "responses": {
          "200": {
            "description": "Список букетів з пагінацією",
            "headers": {
              "x-total-count": { "schema": { "type": "integer" } }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bouquets": { "type": "array", "items": { "$ref": "#/components/schemas/Bouquet" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Створити букет",
        "tags": ["Bouquets"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "price"],
                "properties": {
                  "title": { "type": "string", "example": "Peach Meadow" },
                  "description": { "type": "string", "example": "A delicate spring bouquet" },
                  "price": { "type": "string", "example": "$55" },
                  "photo": { "type": "string", "format": "binary", "description": "Файл зображення (jpeg/png/webp). Якщо не передано — генерується gravatar." }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Букет створено",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/bouquets/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
      ],
      "get": {
        "summary": "Отримати букет за id",
        "tags": ["Bouquets"],
        "responses": {
          "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }, "description": "OK" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "summary": "Оновити букет",
        "tags": ["Bouquets"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BouquetUpdate" } } }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Видалити букет",
        "tags": ["Bouquets"],
        "responses": {
          "200": { "description": "Букет видалено" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/bouquets/{id}/favorite": {
      "patch": {
        "summary": "Переключити статус favorite",
        "tags": ["Bouquets"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } } },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Створити замовлення",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Замовлення створено",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/reviews": {
      "get": {
        "summary": "Список відгуків",
        "tags": ["Reviews"],
        "responses": {
          "200": {
            "description": "Масив відгуків",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Додати відгук",
        "tags": ["Reviews"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReviewCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Відгук додано",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/bouquets/{id}/photo": {
      "patch": {
        "summary": "Оновити фото букету",
        "tags": ["Bouquets"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                },
                "required": ["photo"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Фото оновлено", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "Peach Meadow" },
          "description": { "type": "string", "example": "A delicate spring bouquet" },
          "price": { "type": "string", "example": "$55" },
          "photoURL": { "type": "string", "format": "uri", "example": "https://example.com/photo.jpg" },
          "favorite": { "type": "boolean", "example": false }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": { "type": "string", "example": "Peach Meadow" },
          "description": { "type": "string", "example": "A delicate spring bouquet" },
          "price": { "type": "string", "example": "$55" },
          "photoURL": { "type": "string", "format": "uri" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Ann" },
          "phone": { "type": "string", "example": "+1 (555) 123-4567" },
          "address": { "type": "string", "example": "456 Floral Ave" },
          "message": { "type": "string", "example": "Please deliver in the morning" }
        }
      },
      "OrderCreate": {
        "type": "object",
        "required": ["name", "phone"],
        "properties": {
          "name": { "type": "string", "example": "Ann" },
          "phone": { "type": "string", "example": "+1 (555) 123-4567" },
          "address": { "type": "string", "example": "456 Floral Ave" },
          "message": { "type": "string", "example": "Please deliver in the morning" }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "author": { "type": "string", "example": "Emma T." },
          "quote": { "type": "string", "example": "Flora made my anniversary unforgettable!" }
        }
      },
      "ReviewCreate": {
        "type": "object",
        "required": ["author", "quote"],
        "properties": {
          "author": { "type": "string", "example": "Emma T." },
          "quote": { "type": "string", "example": "Flora made my anniversary unforgettable!" }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "string" },
          "photoURL": { "type": "string", "format": "uri" },
          "favorite": { "type": "boolean" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Некоректний запит",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } }
      },
      "NotFound": {
        "description": "Не знайдено",
        "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string" } } } } }
      }
    }
  }
}
